{
  "name": "ai-incident-analyzer",
  "version": "2.0.0",
  "private": true,
  "description": "AI-powered incident analysis platform with dashboard, PagerDuty integration, and runbook automation",
  "scripts": {
    "dev": "pnpm --filter @incident-analyzer/api dev",
    "dev:dashboard": "pnpm --filter @incident-analyzer/dashboard dev",
    "build": "pnpm -r build",
    "clean": "rm -rf apps/*/dist packages/*/dist",
    "test:e2e": "cd e2e && npx playwright test"
  },
  "keywords": ["incident-analysis", "log-analysis", "ai", "observability", "pagerduty", "runbook"],
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.3.3"
  }
}
