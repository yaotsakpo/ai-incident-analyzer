PORT=3000

# --- MongoDB ---
# If not set, the app runs with in-memory storage (data lost on restart)
# MONGO_URI=mongodb://localhost:27017/incident-analyzer

# --- Analysis Mode ---
# Default: rule-based engine (no API needed, fully testable locally)
# Set to "openai" and provide a key to use LLM-powered analysis
ANALYSIS_MODE=rule-based
# OPENAI_API_KEY=sk-your-openai-key

# --- Integrations ---
# PAGERDUTY_ROUTING_KEY=your-routing-key
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# JIRA_BASE_URL=https://your-org.atlassian.net
# JIRA_PROJECT_KEY=INC
# JIRA_API_TOKEN=your-token
# JIRA_EMAIL=you@example.com
# OPSGENIE_API_KEY=your-key
# AI_PROVIDER=openai
# AI_API_KEY=sk-...
# AI_MODEL=gpt-4
